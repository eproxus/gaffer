[
    {elvis, [
        {config, [
            #{
                dirs => ["src/**"],
                filter => "*.erl",
                ruleset => erl_files_strict,
                rules => [
                    {elvis_style, module_naming_convention, #{
                        regex => "^gaffer"
                    }},
                    {elvis_style, private_data_types, disable},
                    {elvis_style, no_invalid_dynamic_calls, #{
                        ignore => [gaffer, gaffer_queue]
                    }},
                    {elvis_style, state_record_and_type, #{
                        ignore => [gaffer_queue_runner, gaffer_queue_pruner]
                    }},
                    {elvis_style, no_common_caveats_call, #{
                        ignore => [
                            gaffer_queue_runner,
                            gaffer_queue_pruner,
                            gaffer_queue_sup
                        ]
                    }},
                    {elvis_style, dont_repeat_yourself, #{
                        ignore => [gaffer_postgres],
                        min_complexity => 12
                    }},
                    {elvis_style, max_function_length, #{
                        ignore => [gaffer_postgres]
                    }},
                    {elvis_style, max_function_clause_length, #{
                        ignore => [gaffer_postgres]
                    }}
                ]
            },
            #{
                dirs => ["test/**"],
                filter => "*.erl",
                ruleset => erl_files_strict,
                rules => [
                    {elvis_style, no_macros, disable},
                    {elvis_style, no_import, disable},
                    {elvis_style, no_invalid_dynamic_calls, #{
                        ignore => [gaffer_tests, gaffer_test_driver]
                    }},
                    {elvis_style, module_naming_convention, #{
                        regex => "^gaffer"
                    }},
                    {elvis_style, private_data_types, disable},
                    {elvis_style, no_common_caveats_call, #{
                        ignore => [gaffer_tests]
                    }},
                    {elvis_style, dont_repeat_yourself, #{
                        ignore => [gaffer_tests, gaffer_cross_driver_tests]
                    }},
                    {elvis_style, export_used_types, disable},
                    {elvis_style, max_module_length, #{
                        ignore => [gaffer_tests]
                    }},
                    {elvis_style, max_function_length, #{
                        ignore => [
                            gaffer_tests,
                            gaffer_test_worker,
                            gaffer_cross_driver_tests
                        ]
                    }},
                    {elvis_style, max_function_clause_length, #{
                        ignore => [
                            gaffer_tests,
                            gaffer_test_worker,
                            gaffer_cross_driver_tests
                        ]
                    }}
                ]
            },
            #{
                dirs => ["."],
