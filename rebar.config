{deps, [
    {eqwalizer_support,
        {git_subdir, "https://github.com/whatsapp/eqwalizer.git",
            {ref, "c75115d"}, "eqwalizer_support"}}
]}.

{minimum_otp_vsn, "27"}.

{shell, [{apps, [gaffer]}]}.

{erl_opts, [
    debug_info,
    warnings_as_errors,
    warn_export_vars,
    warn_unused_import,
    warn_keywords
]}.

{project_plugins, [
    {rebar3_ex_doc, "0.2.31"},
    {rebar3_hex, "7.1.0"},
    {erlfmt, "1.8.0"},
    {rebar3_lint, "4.2.3"},
    {rebar3_hank, "1.6.0"}
]}.

{erlfmt, [
    write,
    {print_width, 80},
    {files, [
        "elvis.config",
        "include/**/*.hrl",
        "rebar.config{,.script}",
        "src/**/*.{hrl,erl,app.src}",
        "test/**/*.{hrl,erl}"
    ]}
]}.

{alias, [
    {ci, [
        {fmt, "--check"},
        {plugins, "upgrade --all"},
        hank,
        lint,
        {do, "default as test dialyzer"},
        {do, "default as test xref"},
        eunit,
        ex_doc,
        cover
    ]}
]}.

{dialyzer, [
    {plt_apps, all_deps},
    incremental,
    {warnings, [unmatched_returns]},
    %% gaffer_driver_pgo depends on pgo (test-only dep) — analyzed in test profile
    {exclude_mods, [gaffer_driver_pgo]}
]}.

{profiles, [
    {test, [
        {deps, [{unite, "0.4.3"}, {pgo, "0.14.0"}]},
        % Docker compose for Postgres
        {pre_hooks, [{eunit, "docker compose up -d --wait"}]},
        {post_hooks, [{eunit, "docker compose down"}]},
        % Include test folder in static analysis
        {extra_src_dirs, [{"test", [{recursive, true}]}]},
        {xref_extra_paths, ["test"]},
        {dialyzer, [
            {plt_extra_apps, [eunit, pgo]},
            {exclude_mods, []}
        ]},
        % Enable cover
        {cover_enabled, true},
        {cover_opts, [verbose]},
        % Use unite for pretty-printing
        {eunit_opts, [
            no_tty,
            {report, {unite_compact, []}},
            {sys_config, ["config/test.config"]}
        ]}
    ]}
]}.

{hank, [
    {ignore, [
        {"src/gaffer_worker.erl", unused_callbacks},
        {"src/gaffer_driver.erl", unused_callbacks},
        {"test/gaffer_tests.erl", unnecessary_function_arguments},
        {"src/gaffer.erl", [unnecessary_function_arguments], [drain, flush]}
    ]}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.

{ex_doc, [
    {source_url, "https://github.com/eproxu/gaffer"},
    {extras, [
        {"README.md", #{title => "Overview"}},
        {"LICENSE.md", #{title => "License"}},
        {"CODE_OF_CONDUCT.md", #{title => "Code of Conduct"}},
        {"CONTRIBUTING.md", #{title => "Contributing"}},
        {"SECURITY.md", #{title => "Security"}}
    ]},
    {main, "README.md"}
]}.
